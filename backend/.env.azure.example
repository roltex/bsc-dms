# Azure production environment template
# Copy values to Azure Key Vault / App Service Configuration — do NOT commit filled secrets.

APP_NAME="EFES DMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dms.yourcompany.com
APP_TIMEZONE=Asia/Tbilisi

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Azure Database for MySQL Flexible Server
DB_CONNECTION=mysql
DB_HOST=mysql-efes-prod.mysql.database.azure.com
DB_PORT=3306
DB_DATABASE=efes_dms
DB_USERNAME=efes_app
DB_PASSWORD=

# Sessions & Sanctum (same domain SPA + API)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=dms.yourcompany.com
SANCTUM_STATEFUL_DOMAINS=dms.yourcompany.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail — replace with SendGrid, ACS, or SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourcompany.com"
MAIL_FROM_NAME="${APP_NAME}"

# Fresh deploy bootstrap admin (used by ProductionBootstrapSeeder)
PRODUCTION_ADMIN_NAME="System Administrator"
PRODUCTION_ADMIN_EMAIL=admin@yourcompany.com
PRODUCTION_ADMIN_PASSWORD=

# Application Insights (optional — set by Bicep deploy)
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_INSTRUMENTATIONKEY=

# Trust Azure load balancer for HTTPS detection
TRUSTED_PROXIES=*

VITE_APP_NAME="${APP_NAME}"
